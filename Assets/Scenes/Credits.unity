  m_text: "Name: Sci-Fi Sound Effects Library\r\nAuthor: Little Robot Sound Factory\r\nLicense:
    CC-BY 3.0\r\nLink: https://opengameart.org/content/sci-fi-sound-effects-library\r\n\r\nName:
    8 wet squish, slurp impacts\r\nAuthor: Independent.nu\r\nLicense: CC0\r\nLink:
    https://opengameart.org/content/8-wet-squish-slurp-impacts\r\n\r\nName: 37 Hits/Punches\r\nAuthor:
    Independent.nu\r\nLicense: CC0\r\nLink: https://opengameart.org/content/37-hitspunches\r\n\r\nName:
    11 Male Human Pain/Death Sounds\r\nAuthor: Michel Baradari\r\nLicense: CC-By
    3.0\r\nLink: https://opengameart.org/content/11-male-human-paindeath-sounds\r\n\r\nName:
    2 High Quality Explosions\r\nAuthor: Michel Baradari\r\nLicense: CC-BY 3.0\r\nLink:
    https://opengameart.org/content/2-high-quality-explosions\r\n\r\nName: 3 Melee
    Sounds\r\nAuthor: remaxim\r\nLicense: CC0\r\nLink: https://opengameart.org/content/3-melee-sounds\r\n\r\nName:
    Swishes Sound Pack\r\nAuthor: artisticdude\r\nLicense: CC0\r\nLink: https://opengameart.org/content/swishes-sound-packf\n\nSong
    name: Dark Intro\r\nAuthor: Nikke\r\nLicense: CC0\r\nLink: https://opengameart.org/content/dark-intro\r\n\r\nSong
    name: Infestation in the Control Room (Ambience Pack 1 -- Sci Fi Horror)\r\nAuthor:
    Joth\r\nLicense: CC0\r\nLink: https://opengameart.org/content/ambience-pack-1-sci-fi-horror\r\n\r\nSong
    name: Through Space\r\nAuthor: maxstack\r\nLicense: CC-BY-SA 3.0\r\nLink: https://opengameart.org/content/through-space\r\n\r\nSong
    name: Nebula\r\nAuthor: maxstack\r\nLicense: CC-BY-SA 3.0\r\nLink: https://opengameart.org/content/nebula\r\n\r\nSong
    name: restoration completed - Freelance\r\nAuthor: maxstack\r\nLicense: CC-BY-SA
    3.0\r\nLink: https://opengameart.org/content/freelance\r\n\r\nSong name: Hold
    The Fort\r\nAuthor: maxstack\r\nLicense: CC-BY-SA 3.0\r\nLink: https://opengameart.org/content/hold-the-fort\r\n\r\nSong
    name: Cyborg Factory Fight Theme\r\nAuthor: GTDStudio aka Palrom\r\nLicense:
    OGA-BY 3.0\r\nLink: https://opengameart.org/content/cyborg-factory-fight-theme\n\ndi\r\ndi3111\r\n:rofl:
    simplesmente melhor em tudo\r\n\r\ndi \u2014 5/26/2026 11:55 PM\r\njuntaste as
    tuas e do diogo?\r\nricardo \u2014 5/26/2026 11:55 PM\r\nnah\r\ndi \u2014 5/26/2026
    11:55 PM\r\nonde est\xE3o as dele\r\nricardo \u2014 5/26/2026 11:55 PM\r\nmanda-se
    os ficheiros \xE0 parte tbh\r\ngrupo\r\ndi \u2014 5/26/2026 11:55 PM\r\nokok\r\ndi
    \u2014 5/27/2026 1:02 AM\r\nvou enviar agr\r\nricardo \u2014 5/27/2026 1:02 AM\r\nalr\r\ndi
    \u2014 5/27/2026 1:12 AM\r\ndone\r\nricardo \u2014 6/1/2026 1:00 AM\r\nhttps://docs.google.com/presentation/d/1-wRJTBnAoDi15GZIdRjeIDgHITBQuG-WpZEdJZVFzaM/edit?usp=sharing\r\nGoogle
    Docs\r\nL6\r\nL6: Dropout, yet DEEP LEARNING Presented by Diogo Paiva Almeida,
    no.81477 Ricardo Vicente, no.81450\r\n\r\nl6\r\nricardo \u2014 6/1/2026 1:18
    AM\r\nl4, n\xE3o vou fazer ppt\r\nAttachment file type: archive\r\nLab4_MNIST_MLP_v8.zip\r\n91.96
    KB\r\nlab6 notebook\r\nAttachment file type: archive\r\nLab6_Dropout.zip\r\n138.20
    KB\r\nos datasets tens de ir apanhar \xE0 tutoria\r\ndi \u2014 6/2/2026 3:53
    PM\r\nfiz o ppt\r\nhttps://docs.google.com/presentation/d/1ANP27IAYcrhqDdDcwncyic4Z4ILwTInpdGGLk9Np37s/edit?usp=sharing\r\ncome\xE7as
    a partir do 7 ok?\r\nricardo \u2014 6/2/2026 3:54 PM\r\ntens de dar acesso maluco\r\nok\r\ndi
    \u2014 6/2/2026 3:54 PM\r\nhttps://docs.google.com/presentation/d/1ANP27IAYcrhqDdDcwncyic4Z4ILwTInpdGGLk9Np37s/edit?usp=sharing\r\nmuda
    o que quiseres\r\ndesses slides\r\nricardo \u2014 6/2/2026 3:55 PM\r\neu tou
    a melhorar o 6\r\ntemos de ver a divis\xE3o\r\ndi \u2014 6/2/2026 3:55 PM\r\nok\r\npodemos
    fazer igual no 6?\r\ncome\xE7as a partir do 7\r\n\xE3hah\r\nricardo \u2014 6/2/2026
    4:11 PM\r\nok\r\ndi \u2014 7:52 AM\r\nAttachment file type: acrobat\r\nValidac\u0327a\u0303o
    2.pdf\r\n1.07 MB\r\nricardo \u2014 6:36 PM\r\nusing System;\r\nusing System.Collections.Generic;\r\nusing
    UnityEngine;\r\nusing UnityEngine.SceneManagement;\r\n\r\npublic class PlayerPosition
    : MonoBehaviour\r\n{\r\n    [Serializable]\r\n    public class ScenePosition\r\n   
    {\r\n        public string sceneName;\r\n        public Vector3 position;\r\n       
    public Vector3 eulerRotation;\r\n    }\r\n\r\n    [Tooltip(\"Add one entry per
    scene, with the coordinates the player should spawn at in that scene.\")]\r\n   
    [SerializeField] private List<ScenePosition> scenePositions;\r\n\r\n    [Tooltip(\"Optional:
    assign if your player uses a CharacterController (it blocks direct position changes
    otherwise).\")]\r\n    [SerializeField] private CharacterController controller;\r\n\r\n   
    [Tooltip(\"Optional: assign if your player uses a Rigidbody, so velocity gets
    reset on teleport.\")]\r\n    [SerializeField] private Rigidbody rb;\r\n\r\n   
    private void OnEnable()\r\n    {\r\n        SceneManager.sceneLoaded += OnSceneLoaded;\r\n   
    }\r\n\r\n    private void OnDisable()\r\n    {\r\n        SceneManager.sceneLoaded
    -= OnSceneLoaded;\r\n    }\r\n\r\n    private void OnSceneLoaded(Scene scene,
    LoadSceneMode mode)\r\n    {\r\n        ScenePosition match = scenePositions.Find(sp
    => sp.sceneName == scene.name);\r\n\r\n        if (match == null)\r\n       
    {\r\n            Debug.LogWarning($\"No spawn position set for scene '{scene.name}'.
    Player position unchanged.\");\r\n            return;\r\n        }\r\n\r\n       
    MoveTo(match.position, Quaternion.Euler(match.eulerRotation));\r\n    }\r\n\r\n   
    private void MoveTo(Vector3 pos, Quaternion rot)\r\n    {\r\n        if (controller
    != null)\r\n        {\r\n            controller.enabled = false;\r\n           
    transform.SetPositionAndRotation(pos, rot);\r\n            controller.enabled
    = true;\r\n        }\r\n        else\r\n        {\r\n            transform.SetPositionAndRotation(pos,
    rot);\r\n        }\r\n\r\n        if (rb != null)\r\n        {\r\n           
    rb.linearVelocity = Vector3.zero;\r\n            rb.angularVelocity = Vector3.zero;\r\n       
    }\r\n    }\r\n}\r\ndi \u2014 6:39 PM\r\n69.90804\r\n-0.61\r\n5.619004\r\n-92.508\r\n7.669071\r\n-1.022192e-07\r\n9.065973\r\nricardo
    \u2014 7:20 PM\r\nName: Sci-Fi Sound Effects Library\r\nAuthor: Little Robot
    Sound Factory\r\nLicense: CC-BY 3.0\r\nLink: https://opengameart.org/content/sci-fi-sound-effects-library\r\n\r\nName:
    8 wet squish, slurp impacts\r\nAuthor: Independent.nu\r\nLicense: CC0\r\nLink:
    https://opengameart.org/content/8-wet-squish-slurp-impacts\r\n\r\nName: 37 Hits/Punches\r\nAuthor:
    Independent.nu\r\nLicense: CC0\r\nLink: https://opengameart.org/content/37-hitspunches\r\n\r\nName:
    11 Male Human Pain/Death Sounds\r\nAuthor: Michel Baradari\r\nLicense: CC-By
    3.0\r\nLink: https://opengameart.org/content/11-male-human-paindeath-sounds\r\n\r\nName:
    2 High Quality Explosions\r\nAuthor: Michel Baradari\r\nLicense: CC-BY 3.0\r\nLink:
    https://opengameart.org/content/2-high-quality-explosions\r\n\r\nName: 3 Melee
    Sounds\r\nAuthor: remaxim\r\nLicense: CC0\r\nLink: https://opengameart.org/content/3-melee-sounds\r\n\r\nName:
    Swishes Sound Pack\r\nAuthor: artisticdude\r\nLicense: CC0\r\nLink: https://opengameart.org/content/swishes-sound-pack\r\nOpenGameArt.org\r\nSci-Fi
    Sound Effects Library\r\nSci-Fi Sound Effects Library is a powerful collection
    of often used Sci-Fi sound effects for creating a futuristic and high tech experience.
    It contains:2 Alarm Loops1 Alien Language4 Ambiences4 Jingles (Achievement, Win,
    Lose)10 Lasers2 Menu Select1 Robot Activated3 Robot Talk3 SpaceShip Engine Loops3
    WarpDriveTotal: 33 Sci-Fi SFX!All sounds ar...\r\nImage\r\nOpenGameArt.org\r\n8
    wet squish, slurp impacts\r\nsluarschpto find out more, read/translate https://web.archive.org/web/20100307021017/http://www.johannespinter.com/inu/ljudbank.htm\r\nImage\r\nOpenGameArt.org\r\n37
    hits/punches\r\nGame menus, in-game terminals and buttons.. cool stuff!\r\nImage\r\nOpenGameArt.org\r\n11
    male human pain/death sounds\r\nPublished here.\r\nImage\r\nOpenGameArt.org\r\n2
    High Quality Explosions\r\nBoom.Published here.\r\nImage\r\n-\tSci-Fi Essentials
    Kit (Standard)\r\n-\thttps://quaternius.itch.io/sci-fi-essentials-kit\r\n-  \tby
    Quaternius\r\n-\tLicense: CC0, https://quaternius.itch.io/sci-fi-essentials-kit\r\n\r\n-\tModular
    Sci-Fi MEGAKIT (Standard)\r\n\r\nmessage.txt\r\n3 KB\r\n\uFEFF\r\nricardo\r\nshosagi_kanno\r\n
    \r\n \r\nI'm here for a good time, not a long time\r\n-\tSci-Fi Essentials Kit
    (Standard)\r\n-\thttps://quaternius.itch.io/sci-fi-essentials-kit\r\n-  \tby
    Quaternius\r\n-\tLicense: CC0, https://quaternius.itch.io/sci-fi-essentials-kit\r\n\r\n-\tModular
